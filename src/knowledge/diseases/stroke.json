      "factorId": "hypertension_stroke",
      "name": "Hypertension",
      "modifiable": true,
      "evidenceLevel": "meta_analysis",
      "citation": "Blood Pressure and Stroke (Prospective Studies Collaboration meta-analysis)",
      "doi": "10.1161/01.str.0000116869.64771.5a",
      "url": "https://www.ahajournals.org/doi/10.1161/01.str.0000116869.64771.5a",
      "notes": "Per 10 mmHg higher SBP: ~33% higher stroke risk; log-linear from 115 mmHg; consistent across subtypes.",
