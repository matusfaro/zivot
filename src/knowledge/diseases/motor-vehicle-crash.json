  "riskFactors": [
    {
      "factorId": "age_category",
      "name": "Age Category",
      "modifiable": false,
      "evidenceLevel": "high",
      "requiredFields": [
        {
          "path": "demographics.dateOfBirth.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "categorical",
        "strategy": "derived_from_age",
        "categories": [
          { "ageRange": [16, 19], "hazardRatio": 3.0 },
          { "ageRange": [20, 24], "hazardRatio": 2.5 },
          { "ageRange": [25, 64], "hazardRatio": 1.0 },
          { "ageRange": [65, 74], "hazardRatio": 1.1 },
          { "ageRange": [75, 100], "hazardRatio": 1.5 }
        ],
        "referenceCategory": "25-64"
      }
    },
    {
      "factorId": "miles_per_year",
      "name": "Annual Miles Driven",
      "modifiable": true,
      "evidenceLevel": "high",
      "requiredFields": [
        {
          "path": "lifestyle.drivingHabits.milesPerYear.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "continuous",
        "strategy": "log_linear",
        "coefficients": {
          "slope": 0.00003
        },
        "validRange": [0, 50000],
        "notes": "HR increases logarithmically with exposure (miles driven)"
      }
    },
    {
      "factorId": "seat_belt_use",
      "name": "Seat Belt Use",
      "modifiable": true,
      "citation": "Seatbelt Effectiveness Meta-analysis",
      "doi": "10.1016/S0140-6736(02)11721-2",
      "evidenceLevel": "meta_analysis",
      "notes": "Seatbelt use OR=0.5 (50% risk reduction)",
      "requiredFields": [
        {
          "path": "lifestyle.drivingHabits.seatBeltUse.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "categorical",
        "strategy": "lookup",
        "categories": [
          { "value": "always", "hazardRatio": 1.0 },
          { "value": "usually", "hazardRatio": 1.5 },
          { "value": "sometimes", "hazardRatio": 2.5 },
          { "value": "never", "hazardRatio": 4.0 }
        ],
        "referenceCategory": "always"
      }
    },
    {
      "factorId": "alcohol_consumption",
      "name": "Alcohol Consumption",
      "modifiable": true,
      "evidenceLevel": "high",
      "requiredFields": [
        {
          "path": "lifestyle.alcohol.drinksPerWeek.mostRecent.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "continuous",
        "strategy": "linear",
        "coefficients": {
          "slope": 0.05
        },
        "validRange": [0, 50],
        "notes": "HR increases with drinking due to impaired driving risk"
      }
    },
    {
      "factorId": "traffic_violations",
      "name": "Traffic Violations (Past 3 Years)",
      "modifiable": true,
      "evidenceLevel": "medium",
      "requiredFields": [
        {
          "path": "lifestyle.drivingHabits.trafficViolationsPast3Years.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "continuous",
        "strategy": "linear",
        "coefficients": {
          "slope": 0.20
        },
        "validRange": [0, 10],
        "notes": "Each violation increases risk by ~20%"
      }
    },
    {
      "factorId": "phone_use_while_driving",
      "name": "Phone Use While Driving",
      "modifiable": true,
      "evidenceLevel": "high",
      "requiredFields": [
        {
          "path": "lifestyle.drivingHabits.phoneUseWhileDriving.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "categorical",
        "strategy": "lookup",
        "categories": [
          { "value": "never", "hazardRatio": 1.0 },
          { "value": "rare", "hazardRatio": 1.2 },
          { "value": "occasional", "hazardRatio": 1.5 },
          { "value": "frequent", "hazardRatio": 2.0 }
        ],
        "referenceCategory": "never"
      }
    },
    {
      "factorId": "driving_setting",
      "name": "Driving Environment",
      "modifiable": false,
      "evidenceLevel": "medium",
      "requiredFields": [
        {
          "path": "lifestyle.drivingHabits.drivingSetting.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "categorical",
        "strategy": "lookup",
        "categories": [
          { "value": "urban", "hazardRatio": 0.8 },
          { "value": "suburban", "hazardRatio": 1.0 },
          { "value": "rural", "hazardRatio": 1.3 },
          { "value": "mixed", "hazardRatio": 1.0 }
        ],
        "referenceCategory": "suburban"
      }
    }
  ]
