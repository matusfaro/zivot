          { "age": 85, "risk": 0.03733 }
        ]
      },
      {
        "id": "female_us",
        "applicability": {
          "sex": "female",
          "region": ["US"],
          "ageRange": [40, 100]
        },
        "source": "CDC National Vital Statistics (Fall Deaths 2021)",
        "url": "https://www.cdc.gov/injury/wisqars",
