  "riskFactors": [
    {
      "factorId": "ldl_cholesterol",
      "name": "LDL Cholesterol",
      "type": "continuous",
      "evidenceStrength": "strong",
      "category": "Lipids",
      "modifiable": true,
      "citation": "Cholesterol Treatment Trialists' (CTT) Collaboration meta-analysis of statin trials",
      "doi": "10.1016/S0140-6736(10)61350-5",
      "evidenceLevel": "meta_analysis",
      "notes": "Each 1 mmol/L (~39 mg/dL) reduction in LDL-C reduces major vascular events by ~22%",
      "requiredFields": [
        {
          "path": "labTests.lipidPanel.ldlCholesterol.value",
          "required": false,
          "alternatives": ["labTests.markers.ldl_cholesterol.value"]
        }
      ],
      "mapping": {
        "type": "continuous",
        "strategy": "lookup",
        "points": [
          { "value": 70, "hazardRatio": 0.75, "confidence": [0.68, 0.82] },
          { "value": 100, "hazardRatio": 1.0, "confidence": [0.95, 1.05] },
          { "value": 130, "hazardRatio": 1.3, "confidence": [1.22, 1.38] },
          { "value": 160, "hazardRatio": 1.65, "confidence": [1.55, 1.75] },
          { "value": 190, "hazardRatio": 2.05, "confidence": [1.90, 2.20] },
          { "value": 220, "hazardRatio": 2.5, "confidence": [2.30, 2.70] }
        ],
        "validRange": [40, 300]
      }
    },
    {
      "factorId": "hdl_cholesterol",
