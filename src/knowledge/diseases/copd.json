{
  "metadata": {
    "id": "copd_mortality_10year",
    "name": "COPD Mortality (10-year)",
    "category": "respiratory",
    "timeframe": 10,
    "version": "1.1.0",
    "lastUpdated": "2025-01-03",
    "sources": [
      {
        "citation": "ADO Index (Puhan 2009), BODE Index (Celli 2004)",
        "evidenceLevel": "cohort"
      },
      {
        "citation": "NHANES/CDC WONDER COPD Mortality Data",
        "url": "https://wonder.cdc.gov/",
        "evidenceLevel": "cohort"
      }
    ],
    "description": "10-year mortality risk for patients with COPD based on BODE/ADO indices"
  },
  "baselineRisk": {
    "defaultCurve": "male_us",
    "curves": [
      {
        "id": "male_us",
        "applicability": {
          "sex": "male",
          "region": ["US"],
          "ageRange": [40, 100]
        },
        "source": "CDC WONDER Mortality Database - COPD",
        "url": "https://wonder.cdc.gov/",
        "notes": "COPD mortality rates by age/sex from national vital statistics",
        "ageRiskMapping": [
          { "age": 40, "risk": 0.005 },
          { "age": 55, "risk": 0.015 },
          { "age": 65, "risk": 0.045 },
          { "age": 75, "risk": 0.095 }
        ]
      },
      {
        "id": "female_us",
        "applicability": {
          "sex": "female",
          "region": ["US"],
          "ageRange": [40, 100]
        },
        "source": "CDC WONDER Mortality Database - COPD",
        "url": "https://wonder.cdc.gov/",
        "notes": "COPD mortality rates by age/sex from national vital statistics",
        "ageRiskMapping": [
          { "age": 40, "risk": 0.003 },
          { "age": 55, "risk": 0.010 },
          { "age": 65, "risk": 0.032 },
          { "age": 75, "risk": 0.075 }
        ]
      }
    ]
  },
  "riskFactors": [
    {
      "factorId": "copd_diagnosis",
      "name": "COPD Diagnosis",
      "modifiable": false,
      "evidenceLevel": "very_high",
      "requiredFields": [
        {
          "path": "medicalHistory.conditions",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "boolean",
        "trueHazardRatio": 3.5,
        "falseHazardRatio": 1.0
      }
    },
    {
      "factorId": "smoking_copd",
      "name": "Smoking Status",
      "modifiable": true,
      "citation": "Lung Health Study - Pack-years and COPD Mortality",
      "doi": "10.1164/rccm.200506-859OC",
      "evidenceLevel": "cohort",
      "notes": "HR=1.03 per pack-year; linear relationship with cumulative smoking exposure",
      "requiredFields": [
        {
          "path": "lifestyle.smoking.status.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "categorical",
        "categories": [
          { "value": "never", "hazardRatio": 1.0 },
          { "value": "former", "hazardRatio": 1.3 },
          { "value": "current", "hazardRatio": 2.1 }
        ]
      }
    },
    {
      "factorId": "pack_years_copd",
      "name": "Pack-Years of Smoking",
      "modifiable": false,
      "evidenceLevel": "very_high",
      "requiredFields": [
        {
          "path": "lifestyle.smoking.packYears.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "continuous",
        "strategy": "lookup",
        "points": [
          { "value": 0, "hazardRatio": 1.0 },
          { "value": 10, "hazardRatio": 1.3 },
          { "value": 20, "hazardRatio": 1.6 },
          { "value": 30, "hazardRatio": 1.9 },
          { "value": 40, "hazardRatio": 2.2 },
          { "value": 50, "hazardRatio": 2.5 }
        ],
        "validRange": [0, 100]
      }
    },
    {
      "factorId": "bmi_copd",
      "name": "Body Mass Index (Low BMI increases risk)",
      "modifiable": true,
      "evidenceLevel": "high",
      "requiredFields": [
        {
          "path": "biometrics.weight.mostRecent.value.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "continuous",
        "strategy": "lookup",
        "points": [
          { "value": 16, "hazardRatio": 2.2 },
          { "value": 18.5, "hazardRatio": 1.6 },
          { "value": 21, "hazardRatio": 1.2 },
          { "value": 25, "hazardRatio": 1.0 },
          { "value": 30, "hazardRatio": 0.9 },
          { "value": 35, "hazardRatio": 0.85 }
        ],
        "validRange": [12, 50]
      }
    },
    {
      "factorId": "fev1_percent",
      "name": "FEV1 % Predicted (Lung Function)",
      "modifiable": true,
      "evidenceLevel": "very_high",
      "requiredFields": [
        {
          "path": "medicalHistory.respiratoryHistory.fev1Percent.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "continuous",
        "strategy": "lookup",
        "points": [
          { "value": 20, "hazardRatio": 4.5 },
          { "value": 30, "hazardRatio": 3.2 },
          { "value": 40, "hazardRatio": 2.3 },
          { "value": 50, "hazardRatio": 1.7 },
          { "value": 60, "hazardRatio": 1.3 },
          { "value": 70, "hazardRatio": 1.1 },
          { "value": 80, "hazardRatio": 1.0 }
        ],
        "validRange": [10, 100]
      }
    },
    {
      "factorId": "dyspnea_severity",
      "name": "Dyspnea (Shortness of Breath) Severity",
      "modifiable": true,
      "evidenceLevel": "high",
      "requiredFields": [
        {
          "path": "medicalHistory.respiratoryHistory.dyspneaSeverity.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "categorical",
        "categories": [
          { "value": ["none", "0"], "hazardRatio": 1.0 },
          { "value": ["mild", "1"], "hazardRatio": 1.4 },
          { "value": ["moderate", "2"], "hazardRatio": 2.0 },
          { "value": ["severe", "3"], "hazardRatio": 3.2 },
          { "value": ["very_severe", "4"], "hazardRatio": 4.8 }
        ]
      }
    },
    {
      "factorId": "copd_exacerbations",
      "name": "COPD Exacerbations in Past Year",
      "modifiable": true,
      "evidenceLevel": "high",
      "requiredFields": [
        {
          "path": "medicalHistory.respiratoryHistory.exacerbationsPerYear.value",
          "alternatives": []
        }
      ],
      "mapping": {
        "type": "categorical",
        "categories": [
          { "value": ["0", "none"], "hazardRatio": 1.0 },
          { "value": ["1"], "hazardRatio": 1.4 },
          { "value": ["2"], "hazardRatio": 1.9 },
          { "value": ["3", "3+", "multiple"], "hazardRatio": 2.6 }
        ]
      }
    },
    {
      "factorId": "air_pollution_pm25_copd",
      "name": "Air Pollution (PM2.5 Exposure)",
      "type": "categorical",
      "evidenceStrength": "strong",
      "category": "Environmental",
      "modifiable": false,
      "citation": "Liu et al. Ambient air pollution and COPD mortality: a systematic review and meta-analysis. Chronic Obstr Pulm Dis. 2021;8(3):433-442",
      "doi": "10.15326/jcopdf.2021.0207",
      "evidenceLevel": "meta_analysis",
      "notes": "Long-term PM2.5 exposure increases COPD mortality risk by 8-12% per 10 µg/m³. Mechanisms: airway inflammation, oxidative stress, accelerated lung function decline",
      "requiredFields": [
        {
          "path": "lifestyle.airQualityExposure.value",
          "required": false
        }
      ],
      "mapping": {
        "type": "categorical",
        "categories": [
          { "value": "good", "hazardRatio": 1.0, "confidence": [0.95, 1.05] },
          { "value": "moderate", "hazardRatio": 1.05, "confidence": [1.02, 1.08] },
          { "value": "poor", "hazardRatio": 1.10, "confidence": [1.05, 1.15] }
        ]
      }
    }
  ]
}
